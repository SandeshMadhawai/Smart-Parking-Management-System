PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart_parking

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Mock SMS API
SMS_API_KEY=mock_sms_key
SMS_API_URL=https://mock-sms-service.example.com/send

# QR Code base URL (where vehicle owners scan to)
QR_BASE_URL=http://localhost:5173/session
